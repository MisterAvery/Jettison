{
	"manifest_version": 3,
	"name": "Jettison",
	"description": "An Extentsion to Jettison AI From Your Web Presence",
	"version": "1.0",
	"icons": {
		"128": "Galaxy_brain_128.png",
		"64": "Galaxy_brain_64.png",
		"32": "Galaxy_brain_32.png",
		"16": "Galaxy_brain_16.png"

	},
	"content_scripts": [
		{
			"matches": [
				"*://*.google.com/*",
				"*://*.yahoo.com/*",
				"*://*.bing.com/*",
				"*://*.duckduckgo.com/*"
			],
			"js": [
				"app.js"
			]
		}
	]
	
}

